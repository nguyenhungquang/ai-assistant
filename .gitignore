# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/

# Tooling caches
.ruff_cache/
.pytest_cache/
.mypy_cache/

# Local editor / agent state
.obsidian/
.codex

# Internal development docs (not for release)
docs-internal/

# Local runtime state
config.env
system/state.db
system/cache/*
!system/cache/.gitkeep
system/logs/*
