raw/papers/*
!raw/papers/.gitkeep
raw/posts/*
!raw/posts/.gitkeep
raw/extracted/*
!raw/extracted/.gitkeep
raw/html/*
!raw/html/.gitkeep

# Local wiki/runtime artifacts
wiki/papers/*
!wiki/papers/.gitkeep
wiki/posts/*
!wiki/posts/.gitkeep
wiki/topics/*
